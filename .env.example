OPENROUTER_API_KEY=replace_with_your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
LLM_PROVIDER=auto

# Optional fallback if OPENROUTER_API_KEY is not set.
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

HF_TOKEN=replace_with_your_huggingface_token_if_needed

# Optional defaults used by /process-video when omitted.
DEFAULT_TRANSCRIBE_DEVICE=cpu
DEFAULT_WHISPER_MODEL=small
DEFAULT_WHISPER_COMPUTE_TYPE=int8
